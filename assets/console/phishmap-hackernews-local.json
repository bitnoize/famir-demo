{
  "campaign": {
    "campaignId": "hackernews",
    "mirrorDomain": "hackernews.fake",
    "description": "HackerNews local mirror",
    "upgradeSessionPath": "/fake-upgrade-session",
    "sessionCookieName": "fake-sess-hackernews",
    "sessionExpire": 86400000,
    "newSessionExpire": 300000,
    "messageExpire": 3600000
  },
  "proxies": [
    {
      "proxyId": "default",
      "url": "http://localhost:8080",
      "isEnabled": true
    }
  ],
  "targets": [
    {
      "targetId": "root",
      "accessLevel": "landing",
      "donorSecure": true,
      "donorSub": "news",
      "donorDomain": "ycombinator.com",
      "donorPort": 443,
      "mirrorSecure": false,
      "mirrorSub": ".",
      "mirrorPort": 3080,
      "labels": [
        "hackernews"
      ],
      "connectTimeout": 2000,
      "simpleTimeout": 10000,
      "streamTimeout": 60000,
      "headersSizeLimit": 10240,
      "bodySizeLimit": 10485760,
      "mainPage": "<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>hackernews</title>\n    <style>\n      body {\n        font-family: Arial, sans-serif;\n        text-align: center;\n        padding: 10px;\n      }\n    </style>\n  </head>\n  <body>\n    <h1>Hacker News</h1>\n  </body>\n</html>\n",
      "notFoundPage": "<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <title>Not found</title>\n    <style>\n      body {\n        font-family: Arial, sans-serif;\n        text-align: center;\n        padding: 10px;\n      }\n    </style>\n  </head>\n  <body>\n    <h1>Not found</h1>\n  </body>\n</html>\n",
      "faviconIco": "\n",
      "robotsTxt": "User-agent: *\nDisallow: /\n",
      "sitemapXml": "",
      "allowWebSockets": false,
      "isEnabled": true
    },
    {
      "targetId": "google-www",
      "accessLevel": "landing",
      "donorSecure": true,
      "donorSub": "www",
      "donorDomain": "google.com",
      "donorPort": 443,
      "mirrorSecure": false,
      "mirrorSub": "www.google",
      "mirrorPort": 3080,
      "labels": [
        "google"
      ],
      "connectTimeout": 2000,
      "simpleTimeout": 10000,
      "streamTimeout": 60000,
      "headersSizeLimit": 10240,
      "bodySizeLimit": 10485760,
      "mainPage": "",
      "notFoundPage": "",
      "faviconIco": "",
      "robotsTxt": "",
      "sitemapXml": "",
      "allowWebSockets": false,
      "isEnabled": true
    }
  ],
  "redirectors": [
    {
      "redirectorId": "simple",
      "page": "<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<% if (data.og_title) { %>\n    <meta property=\"og:title\" content=\"<%= data.og_title %>\">\n<% } %>\n<% if (data.og_desc) { %>\n    <meta property=\"og:description\" content=\"<%= data.og_desc %>\">\n<% } %>\n<% if (data.og_image) { %>\n    <meta property=\"og:image\" content=\"<%= data.og_image %>\">\n<% } %>\n<% if (data.og_url) { %>\n    <meta property=\"og:url\" content=\"<%= data.og_url %>\">\n<% } %>\n    <title>You will be redirected...</title>\n    <style>\n      body {\n        font-family: Arial, sans-serif;\n        text-align: center;\n        padding: 10px;\n      }\n    </style>\n  </head>\n  <body>\n    <p>You will be redirected...</p>\n    <script>\n<% if (data.upgrade_url) { %>\n      setTimeout(() => {\n        window.location.assign(\"<%= data.upgrade_url %>\");\n      }, 1000);\n<% } %>\n    </script>\n  </body>\n</html>\n",
      "fields": [
        "og_title",
        "og_description"
      ]
    }
  ],
  "lures": [
    {
      "lureId": "test",
      "path": "/foo-bar-baz",
      "redirectorId": "simple",
      "isEnabled": true
    }
  ]
}
